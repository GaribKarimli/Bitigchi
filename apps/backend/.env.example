# ============================================
# Bitigchi Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://bitigchi_user:your_password@localhost:5432/bitigchi_db

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# --- Reddit API (Optional - sentiment falls back to news-only if missing) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@bitigchi.com

# --- App ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ADMIN_DEFAULT_PASSWORD=BitigchiAdmin2024!
