{
  "name": "bitigchi",
  "version": "1.0.0",
  "private": true,
  "description": "Bitigchi — AI Stock Screener & Sentiment Analyzer",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "cd apps/backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build -w apps/frontend",
    "lint": "npm run lint -w apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
